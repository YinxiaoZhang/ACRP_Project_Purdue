from dataclasses import dataclass
import heapq
from typing import Dict, List, Tuple, Optional
from enum import IntEnum

class Size(IntEnum):
    COMPACT = 1
    STANDARD = 2
    OVERSIZED = 3

@dataclass
class Vehicle:
    plate_number: str
    size: Size  # compact, standard, oversized

@dataclass
class Stall:
    stall_id: str
    size: Size  # compact, standard, oversized
    node: str
    available: bool = True

class ParkingAssignmentModule:
    def __init__(self, graph: Dict[str, List[Tuple[str, int]]], stalls: List[Stall], entry_node: str):
        self.graph = graph
        self.stalls = stalls
        self.entry_node = entry_node

    def can_fit(self, vehicle_size: Size, stall_size: Size) -> bool:
        return stall_size >= vehicle_size

    def get_candidate_stalls(self, vehicle: Vehicle) -> List[Stall]:
        return [
            stall for stall in self.stalls
            if stall.available and self.can_fit(vehicle.size, stall.size)
        ]

    def _run_dijkstra_from_entry(self) -> Tuple[Dict[str, float], Dict[str, str]]:
        pq = [(0, self.entry_node)]
        distances = {self.entry_node: 0}
        previous = {}
        visited = set()

        while pq:
            current_dist, current_node = heapq.heappop(pq)

            if current_node in visited:
                continue
            visited.add(current_node)

            for neighbor, weight in self.graph.get(current_node, []):
                new_dist = current_dist + weight
                if neighbor not in distances or new_dist < distances[neighbor]:
                    distances[neighbor] = new_dist
                    previous[neighbor] = current_node
                    heapq.heappush(pq, (new_dist, neighbor))
        
        return distances, previous

    def _reconstruct_path(self, previous: Dict[str, str], start: str, goal: str) -> List[str]:
        path = []
        node = goal
        while node != start:
            path.append(node)
            node = previous[node]
        path.append(start)
        path.reverse()
        return path

    def select_best_stall(self, vehicle: Vehicle) -> Optional[Tuple[Stall, List[str], float]]:
        candidates = self.get_candidate_stalls(vehicle)
        if not candidates:
            return None

        all_distances, all_previous = self._run_dijkstra_from_entry()

        best_stall = None
        min_dist = float("inf")

        for stall in candidates:
            dist = all_distances.get(stall.node, float("inf"))
            if dist < min_dist:
                min_dist = dist
                best_stall = stall

        if best_stall and min_dist != float("inf"):
            path = self._reconstruct_path(all_previous, self.entry_node, best_stall.node)
            return best_stall, path, min_dist
        
        return None

    def assign_stall(self, vehicle: Vehicle):
        result = self.select_best_stall(vehicle)
        if result is None:
            return {"status": "no_available_stall"}

        stall, path, distance = result
        stall.available = False

        return {
            "status": "assigned",
            "vehicle": vehicle.plate_number,
            "stall_id": stall.stall_id,
            "stall_size": stall.size.name,
            "route": path,
            "distance": distance,
        }


